<UserControl x:Class="LifeLine.HrPanel.Desktop.Views.UserControls.PersonalDocuments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifeLine.HrPanel.Desktop.Views.UserControls" 
             xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
             xmlns:features="clr-namespace:LifeLine.HrPanel.Desktop.ViewModels.Features" 
             d:DataContext="{d:DesignInstance Type=features:PersonalDocumentsVM}"
             xmlns:enum="clr-namespace:LifeLine.HrPanel.Desktop.Enums"
             mc:Ignorable="d" 
             d:Height="auto" 
             d:Width="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Arial"/>
            </Style>
            
            <!-- СТИЛЬ ДЛЯ ГРУППИРОВКИ -->
            <Style x:Key="DataGrid.GroupItemStyle" TargetType="GroupItem">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0,0,0,5"/>
                <Setter Property="Background" Value="{StaticResource App.MainColor}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupItem">
                            <Grid Margin="{TemplateBinding Margin}" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ToggleButton x:Name="ExpanderButton" 
                                              IsChecked="True"
                                              Cursor="Hand"
                                              Background="{TemplateBinding Background}"
                                              Padding="{TemplateBinding Padding}"
                                              BorderThickness="0"
                                              HorizontalContentAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="3"
                                                    Margin="{TemplateBinding Padding}" 
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Стрелка по умолчанию (вниз) -->
                                        <Path x:Name="ArrowPath" Fill="White" Margin="13,0,0,0" VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z"/>

                                        <WrapPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="{Binding Name, Converter={StaticResource SaveStatusToStringConverter}}" FontWeight="Bold" FontSize="18" Foreground="#A0D0FF" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontSize="18" Foreground="#88FFFFFF" Margin="8,0,8,0" VerticalAlignment="Center"/>
                                        </WrapPanel>
                                    </Grid>
                                </ToggleButton>

                                <!-- DataGrid автоматически подставляет DataGridRowsPresenter внутрь ItemsPresenter -->
                                <ItemsPresenter x:Name="ItemsPanel" Grid.Row="1" SnapsToDevicePixels="True"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger SourceName="ExpanderButton" Property="IsChecked" Value="False">
                                    <Setter TargetName="ItemsPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ArrowPath" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                    <!-- Стрелка вверх -->
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Список документов -->
        <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="5">
            <Border Margin="10" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                <DataGrid ItemsSource="{Binding PersonalDocuments.PersonalDocumentsView}" 
                          SelectedItem="{Binding PersonalDocuments.SelectedLocalPersonalDocument}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HorizontalContentAlignment="Stretch" 
                          HeadersVisibility="Column"
                          Margin="2"
                          Background="{StaticResource App.MainColor}"
                          d:ItemsSource="{d:SampleData ItemCount=10}">

                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <StaticResource ResourceKey="DataGrid.GroupItemStyle"/>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </DataGrid.GroupStyle>

                    <DataGrid.Columns>
                        <!--Наименование-->
                        <DataGridTemplateColumn Header="Наименование" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DocumentType.Name}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Файл -->
                        <!--<DataGridTemplateColumn Header="Файл" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>-->

                        <!--Информация-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Magnifier}"/>
                                        <Button.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DocumentTypeId, StringFormat=Тип документа: {0}}"/>
                                                <TextBlock Text="{Binding DocumentSeries, StringFormat=Серия: {0}}"/>
                                                <TextBlock Text="{Binding DocumentNumber, StringFormat=Номер: {0}}"/>
                                                <TextBlock Text="{Binding FilePath, StringFormat=Путь: {0}}"/>
                                            </StackPanel>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Удалить-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Foreground="#F06870" 
                                           Command="{Binding DataContext.DeletePersonalDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                           CommandParameter="{Binding }" 
                                           Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Trash}"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

        <!-- Документы -->
        <Border Grid.Column="1" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="5">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <ComboBox ItemsSource="{Binding DocumentTypes}" 
                          SelectedItem="{Binding PersonalDocuments.DocumentType}" 
                          DisplayMemberPath="Name" Margin="0 10 0 0"/>

                    <!-- Серия / Номер -->
                    <Grid Margin="0 10 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <cc:PlaceHolderTextBox Grid.Column="0" 
                                                   PlaceHolder="Номер*" 
                                                   Margin="0 0 5 0"
                                                   Text="{Binding PersonalDocuments.Number, UpdateSourceTrigger=PropertyChanged}" 
                                                   Style="{StaticResource TextBox.PlaceHolder}"/>

                            <cc:PlaceHolderTextBox Grid.Column="1" 
                                                   PlaceHolder="Серия" 
                                                   Margin="5 0 0 0"
                                                   Text="{Binding PersonalDocuments.Series, UpdateSourceTrigger=PropertyChanged}" 
                                                   Style="{StaticResource TextBox.PlaceHolder}"/>
                        </Grid>

                        <!-- Файл -->
                        <StackPanel Grid.Row="1" Margin="0 10 0 0">
                            <Button Content="Выбрать скан" 
                                    Width="170" Height="40" 
                                    HorizontalAlignment="Right"
                                    Command="{Binding PersonalDocuments.SelectMultipleCommand}" 
                                    Style="{StaticResource App.Button}"/>

                            <ListView x:Name="ItemsListView"
                                      ItemsSource="{Binding PersonalDocuments.PendingFilePaths}"
                                      d:ItemsSource="{d:SampleData ItemCount=10}"
                                      Background="#1E1E1E"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <!-- Горизонтальная виртуализация -->

                                <!-- Панель для горизонтального расположения -->
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" 
                                                    IsItemsHost="True"
                                                    Margin="0"/>
                                        <!-- Отступы вокруг всех items -->
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>

                                <!-- Стиль ListViewItem -->
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Margin" Value="0"/>
                                        <!-- Отступ между items -->
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>

                                        <!-- Убираем стандартное выделение -->
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                        <Style.Triggers>
                                            <!-- Выделение при наведении -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                                <Setter Property="Background" Value="Magenta"/>
                                                <Setter Property="BorderBrush" Value="Magenta"/>
                                            </Trigger>

                                            <!-- Выделение выбранного элемента -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#386FD6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <!-- Шаблон элемента (ваш Item) -->
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                                            <!-- Ширина каждого item -->
                                            <Border BorderBrush="#386FD6" 
                                                    Background="{StaticResource App.MainColor}" 
                                                    BorderThickness="2" 
                                                    CornerRadius="10" 
                                                    HorizontalAlignment="Left" 
                                                    VerticalAlignment="Top" 
                                                    Margin="5">
                                                <StackPanel>
                                                    <Border BorderThickness="0 0 0 2" BorderBrush="#386FD6">
                                                        <StackPanel>
                                                            <!-- 👇 Превью: если есть Thumbnail — показываем, иначе заглушка -->
                                                            <Grid Width="150" Height="150" Margin="5">
                                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" 
                                                                       d:Source="C:\Users\texno\Documents\Lightshot\Screenshot_4.png"
                                                                       Visibility="{Binding Thumbnail, Converter={StaticResource NullToVisibilityConverter}}"/>

                                                                <!-- Заглушка если нет превью -->
                                                                <TextBlock Text="{Binding FileExtension}"
                                                                           FontSize="24"
                                                                           FontWeight="Bold"
                                                                           Foreground="#AAAAAA"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                            </Grid>

                                                            <!-- 👇 Индекс и имя файла -->
                                                            <TextBlock Text="{Binding Index, StringFormat='#{0}'}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="18" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding FileName}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="12" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="#AAAAAA"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="140"/>
                                                            <TextBlock Text="{Binding FileSizeFormatted}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="10" 
                                                                       Margin="0 0 0 5"
                                                                       Foreground="#666666"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Кнопки управления -->
                                                    <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 2 0 2">
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Command="{Binding Avatar.SelectCommandAsync}">
                                                            <Control Template="{StaticResource AddIcon}"/>
                                                            <Button.ToolTip>
                                                                <TextBlock Text="Добавить аватарку"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Margin="15 0 15 0"
                                                                Command="{Binding DataContext.PersonalDocuments.PreviewCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding }">
                                                            <Control Template="{StaticResource Magnifier}"/>
                                                        </Button>
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Foreground="#F06870"
                                                                Command="{Binding DataContext.PersonalDocuments.RemovePendingFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding }">
                                                            <Control Template="{StaticResource Trash}"/>
                                                            <Button.ToolTip>
                                                                <TextBlock Text="Удалить"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="1" Content="Добавить локально" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                        Command="{Binding PersonalDocuments.AddPersonalDocumentCommand}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
                <!--Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.CreateStep}, UpdateSourceTrigger=PropertyChanged}"-->

                <Button Grid.Row="2" Content="Продолжить" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                        Command="{Binding ExecuteStepCommand}" 
                        CommandParameter="{x:Static enum:EmployeeCreationSteps.EducationDocuments}"
                        Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.CreateStep}, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

                <Button Grid.Row="2" Content="Сохранить" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Command="{Binding CreatePersonalDocumentCommand}"
                        Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.Create}, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

                <Button Grid.Row="2" Content="Обновить" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        Command="{Binding UpdatePersonalDocumentCommand}"
                        Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.Update}, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
