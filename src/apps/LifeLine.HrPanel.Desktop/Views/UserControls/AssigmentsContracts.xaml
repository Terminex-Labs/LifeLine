<UserControl x:Class="LifeLine.HrPanel.Desktop.Views.UserControls.AssigmentsContracts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifeLine.HrPanel.Desktop.Views.UserControls" 
             xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
             xmlns:features="clr-namespace:LifeLine.HrPanel.Desktop.ViewModels.Features" 
             d:DataContext="{d:DesignInstance Type=features:AssigmentsContractsVM}"
             xmlns:enum="clr-namespace:LifeLine.HrPanel.Desktop.Enums"
             mc:Ignorable="d" 
             d:Height="auto" 
             d:Width="auto">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Arial"/>
            </Style>
            <!-- СТИЛЬ ДЛЯ ГРУППИРОВКИ -->
            <Style x:Key="DataGrid.GroupItemStyle" TargetType="GroupItem">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0,0,0,5"/>
                <Setter Property="Background" Value="{StaticResource App.MainColor}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GroupItem">
                            <Grid Margin="{TemplateBinding Margin}" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <ToggleButton x:Name="ExpanderButton" 
                                              IsChecked="True"
                                              Cursor="Hand"
                                              Background="{TemplateBinding Background}"
                                              Padding="{TemplateBinding Padding}"
                                              BorderThickness="0"
                                              HorizontalContentAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="3"
                                                    Margin="{TemplateBinding Padding}" 
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Стрелка по умолчанию (вниз) -->
                                        <Path x:Name="ArrowPath" Fill="White" Margin="13,0,0,0" VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z"/>

                                        <WrapPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="{Binding Name, Converter={StaticResource SaveStatusToStringConverter}}" FontWeight="Bold" FontSize="18" Foreground="#A0D0FF" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontSize="18" Foreground="#88FFFFFF" Margin="8,0,8,0" VerticalAlignment="Center"/>
                                        </WrapPanel>
                                    </Grid>
                                </ToggleButton>

                                <!-- DataGrid автоматически подставляет DataGridRowsPresenter внутрь ItemsPresenter -->
                                <ItemsPresenter x:Name="ItemsPanel" Grid.Row="1" SnapsToDevicePixels="True"/>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger SourceName="ExpanderButton" Property="IsChecked" Value="False">
                                    <Setter TargetName="ItemsPanel" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ArrowPath" Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                    <!-- Стрелка вверх -->
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!--#region Новый вариант -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0 0 0 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список назначений -->
            <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 5 0">
                <StackPanel>
                    <TextBlock Grid.Row="0" Text="Назначение" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    <Border Margin="5" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                        <DataGrid ItemsSource="{Binding AssigmentsContracts.AssignmentsContractsView}" 
                                  SelectedItem="{Binding AssigmentsContracts.SelectedAssignmentContract}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  HorizontalContentAlignment="Stretch" 
                                  HeadersVisibility="Column"
                                  Margin="2"
                                  Background="{StaticResource App.MainColor}"
                                  d:ItemsSource="{d:SampleData ItemCount=10}">

                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <StaticResource ResourceKey="DataGrid.GroupItemStyle"/>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            
                            <DataGrid.Columns>
                                <!-- Отдел -->
                                <DataGridTemplateColumn Header="Отдел" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Department.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Должность -->
                                <DataGridTemplateColumn Header="Должность" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Position.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Номер контракта -->
                                <DataGridTemplateColumn Header="Номер контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractNumber}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Файл -->
                                <DataGridTemplateColumn Header="Файл" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Информация-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Magnifier}"/>
                                                <Button.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="Назначение"/>
                                                        <TextBlock Text="{Binding Department.Name, StringFormat=Отдел: {0}}"/>
                                                        <TextBlock Text="{Binding Position.Name, StringFormat=Должность: {0}}"/>
                                                        <TextBlock Text="{Binding Manager.Name, StringFormat=Мэнеджер: {0}}"/>
                                                        <TextBlock Text="{Binding HireDate, StringFormat=Дата найма: {0}}"/>
                                                        <TextBlock Text="{Binding TerminationDate, StringFormat=Дата расторжения договора: {0}}"/>
                                                        <TextBlock Text="{Binding Status.Name, StringFormat=Статус: {0}}"/>
                                                        <TextBlock Text="{Binding FilePath.Name, StringFormat=Файл: {0}}"/>

                                                        <TextBlock Text="Контракт" Margin="0 10 0 0"/>
                                                        <TextBlock Text="{Binding EmployeeType.Name, StringFormat=Тип трудоустройства: {0}}"/>
                                                        <TextBlock Text="{Binding ContractNumber, StringFormat=Номер контракта: {0}}"/>
                                                        <TextBlock Text="{Binding StartDate, StringFormat=Начало: {0}}"/>
                                                        <TextBlock Text="{Binding EndDate, StringFormat=Конец: {0}}"/>
                                                        <TextBlock Text="{Binding Salary, StringFormat=Зарплата: {0}}"/>
                                                    </StackPanel>
                                                </Button.ToolTip>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Удалить-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Foreground="#F06870" 
                                                    Command="{Binding AssigmentsContracts.DataContext.DeleteWorkPermitCommand, 
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding }" 
                                                    Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Trash}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Список контрактов -->
            <Border Grid.Column="1" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="5 0 0 0">
                <StackPanel>
                    <TextBlock Grid.Row="0" Text="Контракт" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    <Border Margin="5" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                        <DataGrid ItemsSource="{Binding AssigmentsContracts.AssignmentsContractsView}" 
                                  SelectedItem="{Binding AssigmentsContracts.SelectedAssignmentContract}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  HorizontalContentAlignment="Stretch" 
                                  HeadersVisibility="Column"
                                  Margin="2"
                                  Background="{StaticResource App.MainColor}"
                                  d:ItemsSource="{d:SampleData ItemCount=10}">

                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <StaticResource ResourceKey="DataGrid.GroupItemStyle"/>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            
                            <DataGrid.Columns>
                                <!-- Номер контракта -->
                                <DataGridTemplateColumn Header="Номер контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractNumber}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Тип контракта -->
                                <DataGridTemplateColumn Header="Тип контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EmployeeType.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Оклад -->
                                <DataGridTemplateColumn Header="Оклад" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Salary}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Информация-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Magnifier}"/>
                                                <Button.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="Контракт"/>
                                                        <TextBlock Text="{Binding EmployeeType.Name, StringFormat=Тип трудоустройства: {0}}"/>
                                                        <TextBlock Text="{Binding ContractNumber, StringFormat=Номер контракта: {0}}"/>
                                                        <TextBlock Text="{Binding StartDate, StringFormat=Начало: {0}}"/>
                                                        <TextBlock Text="{Binding EndDate, StringFormat=Конец: {0}}"/>
                                                        <TextBlock Text="{Binding Salary, StringFormat=Зарплата: {0}}"/>
                                                    </StackPanel>
                                                </Button.ToolTip>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Удалить-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Foreground="#F06870" 
                                                    Command="{Binding DataContext.AssigmentsContracts.DeleteAssignmentContractCommand, 
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding }" 
                                                    Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Trash}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 5 0 0">
            <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Назначение -->
                        <StackPanel Grid.Column="0" Margin="0 0 5 0">
                            <TextBlock Grid.Row="0" Text="Назначение" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                            <!-- Отдел / Должность -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding Departments}" 
                                      SelectedItem="{Binding AssigmentsContracts.Department}"
                                      DisplayMemberPath="Name" 
                                      Margin="0 0 5 0"/>

                                <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding AssigmentsContracts.Positions}" 
                                      SelectedItem="{Binding AssigmentsContracts.Position}"
                                      DisplayMemberPath="Name" 
                                      Margin="5 0 0 0"/>
                            </Grid>

                            <!-- Менаджер / Статус -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding Managers}" 
                                      SelectedItem="{Binding AssigmentsContracts.Manager}"
                                      DisplayMemberPath="Name" 
                                      Margin="0 0 5 0"/>

                                <ComboBox Grid.Column="1" 
                                      ItemsSource="{Binding Statuses}" 
                                      SelectedItem="{Binding AssigmentsContracts.Status}"
                                      DisplayMemberPath="Name" 
                                      Margin="5 0 0 0"/>
                            </Grid>

                            <!-- Дата найма / Дата расторжения договора -->
                            <Grid Margin="0 10 0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker Grid.Column="0" SelectedDate="{Binding AssigmentsContracts.HireDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                                <DatePicker Grid.Column="1" SelectedDate="{Binding AssigmentsContracts.TerminationDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Контракт -->
                        <StackPanel Grid.Column="1" Margin="5 0 0 0">
                            <TextBlock Grid.Row="0" Text="Контракт" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                            <!-- Тип трудоустройства / Номер контракта -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" 
                                          ItemsSource="{Binding EmployeeTypes}" 
                                          SelectedItem="{Binding AssigmentsContracts.EmployeeType}"
                                          DisplayMemberPath="Name" 
                                          Margin="0 0 5 0"/>

                                <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Номер контракта*" Margin="0 0 5 0"
                                                       Text="{Binding AssigmentsContracts.ContractNumber, UpdateSourceTrigger=PropertyChanged}" 
                                                       Style="{StaticResource TextBox.PlaceHolder}"/>
                            </Grid>

                            <!-- Дата старта / Дата окончания -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker Grid.Column="0" SelectedDate="{Binding AssigmentsContracts.StartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                                <DatePicker Grid.Column="1" SelectedDate="{Binding AssigmentsContracts.EndDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                            </Grid>

                            <cc:PlaceHolderTextBox PlaceHolder="Зарплата*" Margin="0 10 0 0"
                                                   Text="{Binding AssigmentsContracts.Salary, UpdateSourceTrigger=PropertyChanged}" 
                                                   Style="{StaticResource TextBox.PlaceHolder}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Файл -->
                    <StackPanel Grid.Row="1" Margin="0 10 0 0">
                        <Button Content="Выбрать скан" 
                                    Width="170" Height="40" 
                                    HorizontalAlignment="Right"
                                    Command="{Binding AssigmentsContracts.SelectMultipleCommand}" 
                                    Style="{StaticResource App.Button}"/>

                        <ListView x:Name="ItemsListView"
                                      ItemsSource="{Binding AssigmentsContracts.PendingFilePaths}"
                                      d:ItemsSource="{d:SampleData ItemCount=3}"
                                      Background="#1E1E1E"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <!-- Горизонтальная виртуализация -->

                            <!-- Панель для горизонтального расположения -->
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" 
                                                    IsItemsHost="True"
                                                    Margin="0"/>
                                    <!-- Отступы вокруг всех items -->
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>

                            <!-- Стиль ListViewItem -->
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Margin" Value="0"/>
                                    <!-- Отступ между items -->
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>

                                    <!-- Убираем стандартное выделение -->
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                    <Style.Triggers>
                                        <!-- Выделение при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                            <Setter Property="Background" Value="Magenta"/>
                                            <Setter Property="BorderBrush" Value="Magenta"/>
                                        </Trigger>

                                        <!-- Выделение выбранного элемента -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#386FD6"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <!-- Шаблон элемента (ваш Item) -->
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                                        <!-- Ширина каждого item -->
                                        <Border BorderBrush="#386FD6" 
                                                    Background="{StaticResource App.MainColor}" 
                                                    BorderThickness="2" 
                                                    CornerRadius="10" 
                                                    HorizontalAlignment="Left" 
                                                    VerticalAlignment="Top" 
                                                    Margin="5">
                                            <StackPanel>
                                                <Border BorderThickness="0 0 0 2" BorderBrush="#386FD6">
                                                    <StackPanel>
                                                        <!-- 👇 Превью: если есть Thumbnail — показываем, иначе заглушка -->
                                                        <Grid Width="150" Height="150" Margin="5">
                                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" 
                                                                       d:Source="C:\Users\texno\Documents\Lightshot\Screenshot_4.png"
                                                                       Visibility="{Binding Thumbnail, Converter={StaticResource NullToVisibilityConverter}}"/>

                                                            <!-- Заглушка если нет превью -->
                                                            <TextBlock Text="{Binding FileExtension}"
                                                                           FontSize="24"
                                                                           FontWeight="Bold"
                                                                           Foreground="#AAAAAA"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                        </Grid>

                                                        <!-- 👇 Индекс и имя файла -->
                                                        <TextBlock Text="{Binding Index, StringFormat='#{0}'}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="18" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding FileName}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="12" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="#AAAAAA"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="140"/>
                                                        <TextBlock Text="{Binding FileSizeFormatted}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="10" 
                                                                       Margin="0 0 0 5"
                                                                       Foreground="#666666"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Кнопки управления -->
                                                <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 2 0 2">
                                                    <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Command="{Binding Avatar.SelectCommandAsync}">
                                                        <Control Template="{StaticResource AddIcon}"/>
                                                        <Button.ToolTip>
                                                            <TextBlock Text="Добавить аватарку"/>
                                                        </Button.ToolTip>
                                                    </Button>
                                                    <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Margin="15 0 15 0"
                                                                Command="{Binding Avatar.SelectCommandAsync}">
                                                        <Control Template="{StaticResource Magnifier}"/>
                                                    </Button>
                                                    <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Foreground="#F06870"
                                                                Command="{Binding DataContext.AssigmentsContracts.RemovePendingFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding }">
                                                        <Control Template="{StaticResource Trash}"/>
                                                        <Button.ToolTip>
                                                            <TextBlock Text="Удалить"/>
                                                        </Button.ToolTip>
                                                    </Button>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Добавить локально" Height="40"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Command="{Binding AssigmentsContracts.AddAssignmentContractCommandAsync}"
                Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

        <Button Grid.Row="3" Content="Продолжить" Height="40"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Command="{Binding ExecuteStepCommand}" 
                CommandParameter="{x:Static enum:EmployeeCreationSteps.PersonalInfo}"
                Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.CreateStep}, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

        <Button Grid.Row="3" Content="Сохранить" Height="40"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Command="{Binding CreateAssignmentContractCommand}" 
                Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.Create}, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

        <Button Grid.Row="3" Content="Обновить" Height="40"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Command="{Binding UpdateAssignmentContractCommand}" 
                Visibility="{Binding Action, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TypeActionConverter}, ConverterParameter={x:Static enum:TypeAction.Update}, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
    </Grid>
    <!--#endregion-->

    <!--#region Старый варинт -->
    <!--<Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            --><!-- Список назначений --><!--
            <Border Grid.Row="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 5 5">
                <StackPanel>
                    <TextBlock Grid.Row="0" Text="Назначение" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    <Border Margin="10" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                        <DataGrid ItemsSource="{Binding LocalAssignmentsContracts}" 
                                  SelectedItem="{Binding SelectedWorkPermit}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  HorizontalContentAlignment="Stretch" 
                                  HeadersVisibility="Column"
                                  Margin="2"
                                  Background="{StaticResource App.MainColor}"
                                  d:ItemsSource="{d:SampleData ItemCount=10}">
                            <DataGrid.Columns>
                                --><!-- Отдел --><!--
                                <DataGridTemplateColumn Header="Отдел" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Department.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!-- Должность --><!--
                                <DataGridTemplateColumn Header="Должность" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Position.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!-- Номер контракта --><!--
                                <DataGridTemplateColumn Header="Номер контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractNumber}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!-- Файл --><!--
                                <DataGridTemplateColumn Header="Файл" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!--Информация--><!--
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Magnifier}"/>
                                                <Button.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="Назначение"/>
                                                        <TextBlock Text="{Binding Department.Name, StringFormat=Отдел: {0}}"/>
                                                        <TextBlock Text="{Binding Position.Name, StringFormat=Должность: {0}}"/>
                                                        <TextBlock Text="{Binding Manager.Name, StringFormat=Мэнеджер: {0}}"/>
                                                        <TextBlock Text="{Binding HireDate, StringFormat=Дата найма: {0}}"/>
                                                        <TextBlock Text="{Binding TerminationDate, StringFormat=Дата расторжения договора: {0}}"/>
                                                        <TextBlock Text="{Binding Status.Name, StringFormat=Статус: {0}}"/>
                                                        <TextBlock Text="{Binding FilePath.Name, StringFormat=Файл: {0}}"/>

                                                        <TextBlock Text="Контракт" Margin="0 10 0 0"/>
                                                        <TextBlock Text="{Binding EmployeeType.Name, StringFormat=Тип трудоустройства: {0}}"/>
                                                        <TextBlock Text="{Binding ContractNumber, StringFormat=Номер контракта: {0}}"/>
                                                        <TextBlock Text="{Binding StartDate, StringFormat=Начало: {0}}"/>
                                                        <TextBlock Text="{Binding EndDate, StringFormat=Конец: {0}}"/>
                                                        <TextBlock Text="{Binding Salary, StringFormat=Зарплата: {0}}"/>
                                                    </StackPanel>
                                                </Button.ToolTip>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!--Удалить--><!--
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Foreground="#F06870" 
                                                    Command="{Binding DataContext.DeleteWorkPermitCommand, 
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding }" 
                                                    Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Trash}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>

            --><!-- Список контрактов --><!--
            <Border Grid.Row="1" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 5 5 0">
                <StackPanel>
                    <TextBlock Grid.Row="0" Text="Контракт" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    <Border Margin="10" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                        <DataGrid ItemsSource="{Binding LocalAssignmentsContracts}" 
                                  SelectedItem="{Binding SelectedWorkPermit}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  HorizontalContentAlignment="Stretch" 
                                  HeadersVisibility="Column"
                                  Margin="2"
                                  Background="{StaticResource App.MainColor}"
                                  d:ItemsSource="{d:SampleData ItemCount=10}">
                            <DataGrid.Columns>
                                --><!-- Номер контракта --><!--
                                <DataGridTemplateColumn Header="Номер контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractNumber}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!-- Тип контракта --><!--
                                <DataGridTemplateColumn Header="Тип контракта" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EmployeeType.Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!-- Оклад --><!--
                                <DataGridTemplateColumn Header="Оклад" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Salary}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!--Информация--><!--
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Magnifier}"/>
                                                <Button.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="Контракт"/>
                                                        <TextBlock Text="{Binding EmployeeType.Name, StringFormat=Тип трудоустройства: {0}}"/>
                                                        <TextBlock Text="{Binding ContractNumber, StringFormat=Номер контракта: {0}}"/>
                                                        <TextBlock Text="{Binding StartDate, StringFormat=Начало: {0}}"/>
                                                        <TextBlock Text="{Binding EndDate, StringFormat=Конец: {0}}"/>
                                                        <TextBlock Text="{Binding Salary, StringFormat=Зарплата: {0}}"/>
                                                    </StackPanel>
                                                </Button.ToolTip>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                --><!--Удалить--><!--
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Foreground="#F06870" 
                                                    Command="{Binding DataContext.DeleteWorkPermitCommand, 
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding }" 
                                                    Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Trash}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Column="1" Margin="5 0 0 0" VerticalScrollBarVisibility="Auto">
            <Border Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 0 0">
                <StackPanel Margin="5">
                    --><!--<CheckBox Content="Использовать назначения и контракты" 
                              IsChecked="{Binding IsUseWorkPermit}" 
                              HorizontalAlignment="Center" DockPanel.Dock="Right" Margin="0 0 0 10" 
                              Style="{StaticResource BaseChechBox}"/>--><!--

                    <TextBlock Grid.Row="0" Text="Назначение" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    --><!-- Отдел / Должность --><!--
                    <Grid Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding Departments}" 
                                  SelectedItem="{Binding NewAssignmentContract.Department}"
                                  DisplayMemberPath="Name" 
                                  Margin="0 0 5 0"/>

                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding Positions}" 
                                  SelectedItem="{Binding NewAssignmentContract.Position}"
                                  DisplayMemberPath="Name" 
                                  Margin="5 0 0 0"/>
                    </Grid>

                    --><!-- Менаджер / Статус --><!--
                    <Grid Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding Managers}" 
                                  SelectedItem="{Binding NewAssignmentContract.Manager}"
                                  DisplayMemberPath="Name" 
                                  Margin="0 0 5 0"/>

                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding Statuses}" 
                                  SelectedItem="{Binding NewAssignmentContract.Status}"
                                  DisplayMemberPath="Name" 
                                  Margin="5 0 0 0"/>
                    </Grid>

                    --><!-- Дата найма / Дата расторжения договора --><!--
                    <Grid Margin="0 10 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DatePicker Grid.Column="0" SelectedDate="{Binding NewAssignmentContract.HireDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                        <DatePicker Grid.Column="1" SelectedDate="{Binding NewAssignmentContract.TerminationDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                    </Grid>

                    <TextBlock Grid.Row="0" Text="Контракт" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                    --><!-- Тип трудоустройства / Номер контракта --><!--
                    <Grid Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding EmployeeTypes}" 
                                  SelectedItem="{Binding NewAssignmentContract.EmployeeType}"
                                  DisplayMemberPath="Name" 
                                  Margin="0 0 5 0"/>

                        <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Номер контракта*" Margin="0 0 5 0"
                                               Text="{Binding NewAssignmentContract.ContractNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>
                    </Grid>

                    --><!-- Дата старта / Дата окончания --><!--
                    <Grid Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DatePicker Grid.Column="0" SelectedDate="{Binding NewAssignmentContract.StartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                        <DatePicker Grid.Column="1" SelectedDate="{Binding NewAssignmentContract.EndDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                    </Grid>

                    <cc:PlaceHolderTextBox PlaceHolder="Зарплата*" Margin="0 10 0 0"
                                           Text="{Binding NewAssignmentContract.Salary, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                    --><!-- Файл --><!--
                    <DockPanel Margin="0 10 0 0">
                        <Button Width="25" Foreground="#F06870" 
                                Command="{Binding SelectAssignmentContractFileCommand}" 
                                DockPanel.Dock="Right"
                                Style="{StaticResource Button.Icon}">
                            <Control Template="{StaticResource AddIcon}"/>
                            <Button.ToolTip>
                                <TextBlock Text="Добавить файл назначения"/>
                            </Button.ToolTip>
                        </Button>
                        <cc:PlaceHolderTextBox PlaceHolder="Файл" 
                                               Text="{Binding NewAssignmentContract.FilePath}" 
                                               Style="{StaticResource TextBox.PlaceHolder}"/>
                    </DockPanel>

                    <Button Content="Добавить"
                            HorizontalAlignment="Center" Width="250" Height="40"
                            Command="{Binding AddAssignmentContractCommand}"
                            Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>-->
    <!--#endregion-->
</UserControl>
