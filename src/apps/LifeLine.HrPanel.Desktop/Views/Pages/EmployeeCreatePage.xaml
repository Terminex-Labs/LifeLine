                                                  d:ItemsSource="{d:SampleData ItemCount=10}">
                                            <DataGrid.Columns>
                                                <!-- Номер контракта -->
                                                <DataGridTemplateColumn Header="Номер контракта" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ContractNumber}" 
                                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <!-- Тип контракта -->
                                                <DataGridTemplateColumn Header="Тип контракта" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding EmployeeType.Name}" 
                                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <!-- Оклад -->
                                                <DataGridTemplateColumn Header="Оклад" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Salary}" 
                                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <!--Информация-->
                                                <DataGridTemplateColumn Width="35">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                                <Control Template="{StaticResource Magnifier}"/>
                                                                <Button.ToolTip>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{StaticResource String.Contracts}"/>
                                                                        <TextBlock Text="{Binding EmployeeType.Name, StringFormat=Тип трудоустройства: {0}}"/>
                                                                        <TextBlock Text="{Binding ContractNumber, StringFormat=Номер контракта: {0}}"/>
                                                                        <TextBlock Text="{Binding StartDate, StringFormat=Начало: {0}}"/>
                                                                        <TextBlock Text="{Binding EndDate, StringFormat=Конец: {0}}"/>
                                                                        <TextBlock Text="{Binding Salary, StringFormat=Зарплата: {0}}"/>
                                                                    </StackPanel>
                                                                </Button.ToolTip>
                                                            </Button>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>

                                                <!--Удалить-->
                                                <DataGridTemplateColumn Width="35">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Width="25" Foreground="#F06870" 
                                                                    Command="{Binding DataContext.DeleteWorkPermitCommand, 
                                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                                    CommandParameter="{Binding }" 
                                                                    Style="{StaticResource Button.Icon}">
                                                                <Control Template="{StaticResource Trash}"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Column="1" Margin="5 0 0 0" VerticalScrollBarVisibility="Auto">
                            <Border Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 0 0">
                                <StackPanel Margin="5">
                                    <CheckBox Content="Использовать назначения и контракты" 
                                              IsChecked="{Binding IsUseWorkPermit}" 
                                              HorizontalAlignment="Center" DockPanel.Dock="Right" Margin="0 0 0 10" 
                                              Style="{StaticResource BaseChechBox}"/>

                                    <TextBlock Grid.Row="0" Text="{StaticResource String.Assigments}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                    <!-- Отдел / Должность -->
                                    <Grid Margin="0 10 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding Departments}" 
                                                  SelectedItem="{Binding NewAssignmentContract.Department}"
                                                  DisplayMemberPath="Name" 
                                                  Margin="0 0 5 0"/>

                                        <ComboBox Grid.Column="1" 
                                                  ItemsSource="{Binding Positions}" 
                                                  SelectedItem="{Binding NewAssignmentContract.Position}"
                                                  DisplayMemberPath="Name" 
                                                  Margin="5 0 0 0"/>
                                    </Grid>

                                    <!-- Менаджер / Статус -->
                                    <Grid Margin="0 10 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding Managers}" 
                                                  SelectedItem="{Binding NewAssignmentContract.Manager}"
                                                  DisplayMemberPath="Name" 
                                                  Margin="0 0 5 0"/>

                                        <ComboBox Grid.Column="1" 
                                                  ItemsSource="{Binding Statuses}" 
                                                  SelectedItem="{Binding NewAssignmentContract.Status}"
                                                  DisplayMemberPath="Name" 
                                                  Margin="5 0 0 0"/>
                                    </Grid>

                                    <!-- Дата найма / Дата расторжения договора -->
                                    <Grid Margin="0 10 0 10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <DatePicker Grid.Column="0" SelectedDate="{Binding NewAssignmentContract.HireDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                                        <DatePicker Grid.Column="1" SelectedDate="{Binding NewAssignmentContract.TerminationDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                                    </Grid>

                                    <TextBlock Grid.Row="0" Text="{StaticResource String.Contracts}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                    <!-- Тип трудоустройства / Номер контракта -->
                                    <Grid Margin="0 10 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" 
                                                  ItemsSource="{Binding EmployeeTypes}" 
                                                  SelectedItem="{Binding NewAssignmentContract.EmployeeType}"
                                                  DisplayMemberPath="Name" 
                                                  Margin="0 0 5 0"/>

                                        <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Номер контракта*" Margin="0 0 5 0"
                                                               Text="{Binding NewAssignmentContract.ContractNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>
                                    </Grid>

                                    <!-- Дата старта / Дата окончания -->
                                    <Grid Margin="0 10 0 0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <DatePicker Grid.Column="0" SelectedDate="{Binding NewAssignmentContract.StartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 5 0"/>

                                        <DatePicker Grid.Column="1" SelectedDate="{Binding NewAssignmentContract.EndDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                                    </Grid>

                                    <cc:PlaceHolderTextBox PlaceHolder="Зарплата*" Margin="0 10 0 0"
                                                           Text="{Binding NewAssignmentContract.Salary, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                                    <!-- Файл -->
                                    <DockPanel Margin="0 10 0 0">
                                        <Button Width="25" Foreground="#F06870" 
                                                Command="{Binding SelectAssignmentContractFileCommand}" 
                                                DockPanel.Dock="Right"
                                                Style="{StaticResource Button.Icon}">
                                            <Control Template="{StaticResource AddIcon}"/>
                                            <Button.ToolTip>
                                                <TextBlock Text="Добавить файл назначения"/>
                                            </Button.ToolTip>
                                        </Button>
                                        <cc:PlaceHolderTextBox PlaceHolder="Файл" 
                                                               Text="{Binding NewAssignmentContract.FilePath}" 
                                                               Style="{StaticResource TextBox.PlaceHolder}"/>
                                    </DockPanel>

                                    <Button Content="Добавить"
                                            HorizontalAlignment="Center" Width="250" Height="40"
                                            Command="{Binding AddAssignmentContractCommand}"
                                            Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
